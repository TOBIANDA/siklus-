### WebSocket Configuration ###
# Port untuk WebSocket server (default: 3000)
WEBSOCKET_PORT=3000

# URL WebSocket untuk frontend (sesuaikan dengan domain)
VITE_WEBSOCKET_URL=http://localhost:3000

# Untuk production, gunakan:
# VITE_WEBSOCKET_URL=https://yourdomain.com

# WebSocket transports (websocket, polling, atau keduanya)
WEBSOCKET_TRANSPORTS=websocket,polling

# WebSocket connection timeout (dalam ms)
WEBSOCKET_TIMEOUT=5000
